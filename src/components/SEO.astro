---
/**
 * Optional SEO / Open Graph / Twitter meta. Each tag renders only when its
 * backing prop is set. Pass `ogTitle` separately from the document `<title>`
 * when you want a shorter share title (e.g. post title vs "Post | Site").
 */
export interface SEOData {
	description?: string;
	canonicalUrl?: string;
	ogTitle?: string;
	ogImage?: string;
	ogImageAlt?: string;
	ogType?: string;
	/** ISO 8601; use with `ogType: 'article'` for Facebook / LinkedIn-style previews */
	articlePublishedTime?: string;
	/** ISO 8601; optional companion to `articlePublishedTime` */
	articleModifiedTime?: string;
	twitterCard?: 'summary' | 'summary_large_image';
}

interface Props {
	seo?: SEOData;
}

const { seo } = Astro.props;
---

{
	seo && (
		<>
			{seo.description && (
				<>
					<meta name="description" content={seo.description} />
					<meta property="og:description" content={seo.description} />
				</>
			)}
			{seo.canonicalUrl && (
				<>
					<link rel="canonical" href={seo.canonicalUrl} />
					<meta property="og:url" content={seo.canonicalUrl} />
				</>
			)}
			{seo.ogTitle && <meta property="og:title" content={seo.ogTitle} />}
			{seo.ogType && <meta property="og:type" content={seo.ogType} />}
			{seo.ogImage && <meta property="og:image" content={seo.ogImage} />}
			{seo.ogImage && seo.ogImageAlt && (
				<meta property="og:image:alt" content={seo.ogImageAlt} />
			)}
			{seo.articlePublishedTime && (
				<meta
					property="article:published_time"
					content={seo.articlePublishedTime}
				/>
			)}
			{seo.articleModifiedTime && (
				<meta
					property="article:modified_time"
					content={seo.articleModifiedTime}
				/>
			)}
			{seo.twitterCard && (
				<>
					<meta name="twitter:card" content={seo.twitterCard} />
					{seo.ogTitle && (
						<meta name="twitter:title" content={seo.ogTitle} />
					)}
					{seo.description && (
						<meta name="twitter:description" content={seo.description} />
					)}
					{seo.ogImage && (
						<meta name="twitter:image" content={seo.ogImage} />
					)}
					{seo.ogImage && seo.ogImageAlt && (
						<meta name="twitter:image:alt" content={seo.ogImageAlt} />
					)}
				</>
			)}
		</>
	)
}
