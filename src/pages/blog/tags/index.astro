---
import Container from '../../../components/Container.astro';
import Layout from '../../../layouts/Layout.astro';
import Hero from '../../../components/Hero.astro';
import TaxonomyList from '../../../components/TaxonomyList.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type BlogPost = CollectionEntry<'blog'>;
type BlogTag = BlogPost['data']['tags'][number];

const allPosts = await getCollection('blog');
const tagBySlug = new Map<string, BlogTag>();
for (const post of allPosts) {
    for (const tag of post.data.tags) {
        if (!tagBySlug.has(tag.slug)) tagBySlug.set(tag.slug, tag);
    }
}
const tags = [...tagBySlug.values()].sort((a, b) => a.label.localeCompare(b.label));
---

<Layout
    title="Blog Tags | Geoff Dusome"
    seo={{
        description: 'Browse posts by tag.',
        canonicalUrl: 'https://geoffduso.me/blog/tags',
        ogTitle: 'Blog Tags | Geoff Dusome',
        ogType: 'website',
        twitterCard: 'summary',
    }}
>
    <Container>
        <Hero title="Tags">
            <p>
                Topics used across posts. You can also browse by
                <a href="/blog/categories" class="animated-underline">category</a> or return to the
                <a href="/blog" class="animated-underline">blog</a>.
            </p>
        </Hero>
        <TaxonomyList
            items={tags}
            hrefBase="/blog/tags"
            emptyMessage="No tags yet."
        />
    </Container>
</Layout>
